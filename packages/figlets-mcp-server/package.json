{
  "name": "@figlets/mcp-server",
  "version": "0.1.0",
  "description": "Agent-agnostic MCP server for Figma design system workflows. Bundled with the Claude Code marketplace at plugins/claude-code/ for one-command install.",
  "keywords": [
    "figma",
    "design-system",
    "mcp",
    "model-context-protocol",
    "claude-code",
    "figlets"
  ],
  "license": "MIT",
  "main": "src/index.js",
  "bin": {
    "figlets-mcp": "bin/figlets-mcp.js"
  },
  "files": [
    "bin/",
    "src/",
    "plugins/",
    "README.md"
  ],
  "scripts": {
    "start": "node src/index.js",
    "launch": "node src/cli/launch.js",
    "setup": "node src/cli/setup.js",
    "doctor": "node src/cli/doctor.js",
    "detect-ds": "node src/cli/detect-design-system.js",
    "export-figma-file": "node src/cli/export-figma-file.js",
    "inspect-component": "node src/cli/inspect-component.js",
    "prepack": "node scripts/sync-plugins.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
